# Copy this to .env on the server and fill in the values
# Never commit .env to git

# A long random string for signing session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# ClickHouse credentials — must match docker-compose.yml environment
CLICKHOUSE_PASSWORD=change_this_to_a_strong_password
